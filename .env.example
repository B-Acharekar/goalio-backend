APP_ENV=development
FIREBASE_PROJECT_ID=goalio-c42bc
# Use one of these credential methods. Keep both unset when the host provides
# Application Default Credentials (for example, Google Cloud).
# GOOGLE_APPLICATION_CREDENTIALS=C:/secure/path/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
ALLOWED_ORIGINS=http://localhost:3000
ALLOW_DEV_AUTH=false

# When true together with APP_ENV=development, unauthenticated local Swagger
# requests use the isolated uid "swagger-user". Never enable in production.
